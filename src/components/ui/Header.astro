<header class="text-center relative px-4 pt-4 md:pt-10 z-20">
  <div class="relative inline-block">
    <div class="absolute -inset-3 rounded-full bg-brand-pink/40 blur-xl pointer-events-none"></div>

    <div class="animate-entrance relative 
                w-40 h-40 
                md:w-56 md:h-56 
                flex items-center justify-center mx-auto">
      
      <img 
        src="/images/logocircular.png" 
        alt="Amuleto Logo" 
        class="w-full h-full object-contain" 
      />
    </div>
  </div>
</header>

<style is:global>
  /* --- Animación de Entrada del Logo --- */
  @keyframes entrance {
    0% { 
      opacity: 0; 
      transform: scale(0.9) translateY(10px); 
    }
    100% { 
      opacity: 1; 
      transform: scale(1) translateY(0); 
    }
  }

  .animate-entrance { 
    animation: entrance 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
  }

  /* Ajuste para pantallas pequeñas */
  @media (max-height: 670px) {
    header { padding-top: 1rem; }
    .animate-entrance {
      width: 8rem; 
      height: 8rem;
    }
  }
</style>