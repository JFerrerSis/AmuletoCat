---
import { ArrowLeft, ChevronLeft, ChevronRight } from "lucide-astro";
import CatalogLayout from "../../../layouts/CatalogoLayout.astro";
import ProductCard from "../../../components/ui/ProductCard.astro";
import productosData from "../../../data/productos.json";
import type { Product } from "../../../types/product";

export async function getStaticPaths() {
  const products = productosData as Product[];
  return products.map((product) => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props;
const allProducts = productosData as Product[];

const tieneImagenes = product.imagenes && product.imagenes.length > 1;
const listaImagenes: string[] = (product.imagenes && product.imagenes.length > 0) 
  ? product.imagenes 
  : [product.imagen];

const relacionados = allProducts
  .filter(p => (p.subcategoria === product.subcategoria || p.categoria === product.categoria) && p.id !== product.id)
  .sort((a, b) => (a.subcategoria === product.subcategoria ? -1 : 1))
  .slice(0, 4);

// Formato a Dólares ($)
const formattedPrice = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  minimumFractionDigits: 0,
}).format(product.precio);

const productString = JSON.stringify(product);
---

<CatalogLayout title={`${product.nombre} | Amuleto`}>
  <main class="max-w-6xl mx-auto px-6 pt-32 md:pt-40 pb-24 relative overflow-hidden">
    <a href="/catalogo" class="inline-flex items-center gap-3 text-brand-purple/40 hover:text-brand-gold transition-all text-[10px] uppercase tracking-[0.3em] mb-12 group">
      <span class="bg-white shadow-sm rounded-full w-8 h-8 flex items-center justify-center group-hover:-translate-x-1 transition-transform">
        <ArrowLeft size={14} strokeWidth={2.5} />
      </span>
      <span>Regresar al Catálogo</span>
    </a>

    <div class="grid lg:grid-cols-2 gap-8 md:gap-16 items-start">
      <div class="relative aspect-[4/5] w-full overflow-hidden bg-brand-pink/5 border border-brand-purple/5 rounded-3xl shadow-xl animate-fast-up group/carousel">
        
        <div id="carousel-track" class="flex h-full w-full transition-transform duration-500 ease-in-out">
          {listaImagenes.map((img: string, index: number) => (
            <div class="w-full h-full flex-shrink-0">
              <img 
                src={img} 
                alt={`${product.nombre} - vista ${index + 1}`} 
                class="w-full h-full object-cover"
                style={index === 0 ? `view-transition-name: card-${product.id};` : ''} 
              />
            </div>
          ))}
        </div>

        {tieneImagenes && (
          <>
            <button id="prev-btn" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-brand-purple transition-all shadow-md hover:bg-brand-gold hover:text-white active:scale-90 md:opacity-0 md:group-hover/carousel:opacity-100">
              <ChevronLeft size={20} />
            </button>
            <button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-brand-purple transition-all shadow-md hover:bg-brand-gold hover:text-white active:scale-90 md:opacity-0 md:group-hover/carousel:opacity-100">
              <ChevronRight size={20} />
            </button>

            <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2.5">
              {listaImagenes.map((_, i) => (
                <div class={`dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300 ${i === 0 ? "bg-white !w-6" : ""}`} data-index={i} />
              ))}
            </div>
          </>
        )}

        <div class="absolute top-6 left-6 z-10">
          <div class="bg-white/90 backdrop-blur-md border border-brand-gold/20 px-4 py-1.5 rounded-full shadow-sm">
            <p class="text-[9px] font-bold text-brand-gold tracking-[0.2em] uppercase">{product.categoria}</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col space-y-8 md:pt-4">
        <header class="animate-fast-left">
          <div class="w-12 h-0.5 bg-brand-gold mb-6"></div>
          <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-tight text-brand-purple mb-4 leading-tight">
            {product.nombre}
          </h1>
          <span class="text-[10px] font-bold text-brand-purple/30 tracking-[0.4em] uppercase">Pieza Artesanal Exclusiva</span>
        </header>

        <div class="space-y-8 animate-fade-in">
          <p class="text-brand-purple/70 text-base md:text-lg font-light leading-relaxed max-w-md">
            {product.descripcion}
          </p>

          <div class="flex flex-col pt-6 border-t border-brand-purple/5">
            <span class="text-[10px] font-bold text-brand-purple/30 uppercase tracking-widest mb-1">Precio</span>
            <span class="text-5xl font-bold text-brand-purple tracking-tighter">{formattedPrice}</span>
          </div>

          <button
            id="add-to-cart-detail"
            class="w-full md:w-auto px-12 py-5 bg-brand-purple text-white font-bold uppercase text-[11px] tracking-[0.3em] rounded-2xl hover:bg-brand-gold transition-all duration-500 shadow-xl shadow-brand-purple/10 active:scale-95"
            data-product={productString}
          >
            Añadir al carrito
          </button>
        </div>
      </div>
    </div>
  </main>
</CatalogLayout>

<script>
  import { addToCart } from "../../../store/cartStore";

  function initProductDetail() {
    const track = document.getElementById("carousel-track");
    const nextBtn = document.getElementById("next-btn");
    const prevBtn = document.getElementById("prev-btn");
    const dots = document.querySelectorAll(".dot");
    const addBtn = document.getElementById("add-to-cart-detail");

    if (track && nextBtn && prevBtn) {
      let currentIndex = 0;
      const slides = track.children;
      const maxSlides = slides.length;

      const updateCarousel = () => {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        dots.forEach((dot, i) => {
          if (i === currentIndex) {
            dot.classList.add("bg-white", "!w-6");
            dot.classList.remove("bg-white/40");
          } else {
            dot.classList.remove("bg-white", "!w-6");
            dot.classList.add("bg-white/40");
          }
        });
      };

      // Usamos event listeners limpios
      nextBtn.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % maxSlides;
        updateCarousel();
      });

      prevBtn.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + maxSlides) % maxSlides;
        updateCarousel();
      });
    }

    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const productData = JSON.parse(addBtn.dataset.product || "{}");
        addToCart(productData);
        
        const originalText = addBtn.innerHTML;
        addBtn.innerHTML = "¡AÑADIDO!";
        addBtn.classList.add('!bg-brand-gold');
        
        setTimeout(() => {
          addBtn.innerHTML = originalText;
          addBtn.classList.remove('!bg-brand-gold');
        }, 1500);
      });
    }
  }

  // Correr al cargar y al navegar con ViewTransitions
  document.addEventListener("astro:page-load", initProductDetail);
</script>

<style>
  /* Fix de estructura para responsive */
  #carousel-track > div {
    min-width: 100%;
    width: 100%;
  }

  /* Animaciones */
  .animate-fast-up { animation: quickUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fast-left { animation: quickLeft 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fade-in { animation: quickFade 0.8s ease-out both; }

  @keyframes quickUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  @keyframes quickLeft { from { transform: translateX(-20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes quickFade { from { opacity: 0; } to { opacity: 1; } }
</style>