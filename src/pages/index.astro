---
import Layout from '../layouts/Layout.astro';
import LinkCard from '../components/ui/LinkCard.astro';
import Header from '../components/ui/Header.astro';

// Importación corregida de iconos
import { Handbag, MessageCircle, Instagram } from 'lucide-astro';

const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const message = "¡Hola Amuleto! ✨ Me gustaría obtener información sobre sus accesorios.";
const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<Layout title="Amuleto | Accesorios Hechos a Mano">
  <div 
    class="flex flex-col items-center justify-center h-screen w-full max-w-100 md:max-w-105 mx-auto px-6 relative z-10 py-8 overflow-hidden"
  >
    <div class="relative z-20 w-full md:scale-95">
      <Header />
    </div>

    <div class="w-full flex flex-col space-y-5 md:space-y-5 relative z-10 mt-10">
      
      <LinkCard 
        title="Catálogo Digital" 
        href="/catalogo" 
        colorClass="border-brand-gold border-2 shadow-sm"
      >
        <Handbag slot="icon" size="20" stroke-width="2.5" class="text-brand-gold" />
      </LinkCard>
      
      <LinkCard 
        title="WhatsApp" 
        href={whatsappUrl} 
        colorClass="border-brand-purple border-2 shadow-sm"
      >
        <MessageCircle slot="icon" size="20" stroke-width="2.5" class="text-brand-purple" />
      </LinkCard>

      <LinkCard 
        title="Instagram"
        href="https://www.instagram.com/amuleto.ve/" 
        colorClass="border-brand-pink border-2 shadow-sm"
      >
        <Instagram slot="icon" size="20" stroke-width="2.5" class="text-brand-pink" />
      </LinkCard>

    </div>
  </div>
</Layout>

<style>
  /* Estilos base corregidos y estáticos */
  :global(.link-luxury) {
    background-color: white !important;
    border-radius: 1.15rem !important;
    display: flex !important;
    transition: all 0.3s ease-out !important;
  }

  /* Mantenemos una reacción muy sutil al hover para que el usuario sepa que es clickable */
  :global(.link-luxury:hover) {
    transform: translateY(-2px) !important;
    box-shadow: 0 10px 20px -5px rgba(59, 27, 84, 0.08) !important;
  }

  :global(.link-luxury span) {
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    color: #3b1b54 !important;
    font-size: 0.75rem !important;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    :global(.link-luxury span) { font-size: 0.8rem !important; }
  }
</style>