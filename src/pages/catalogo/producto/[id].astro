---
import { ArrowLeft } from 'lucide-astro';
import CatalogLayout from '../../../layouts/CatalogoLayout.astro';
import ProductCard from '../../../components/ui/ProductCard.astro';
import productosData from '../../../data/productos.json'; 
import type { Product } from '../../../types/product';

export async function getStaticPaths() {
  const products = (productosData as Product[]);
  return products.map((product) => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props;

const allProducts = (productosData as Product[]);
const relacionados = allProducts
  .filter(p => p.categoria === product.categoria && p.id !== product.id)
  .slice(0, 4);

const productString = JSON.stringify(product);
---

<CatalogLayout title={`${product.nombre} | Amuleto`}>
  <main class="max-w-6xl mx-auto px-6 pt-32 md:pt-40 pb-24 relative overflow-hidden bg-brand-pink/0.5">
    
   <a 
  href="/catalogo" 
  data-astro-history="replace"
  class="inline-flex items-center gap-3 text-brand-purple/40 hover:text-brand-gold transition-all text-[10px] uppercase tracking-[0.3em] mb-12 group animate-fade-in"
>
  <span class="group-hover:-translate-x-1 transition-transform bg-white shadow-sm rounded-full w-8 h-8 flex items-center justify-center">
    <ArrowLeft size={14} strokeWidth={2.5} />
  </span> 
  <span>Regresar al Catálogo</span>
</a>

    <div class="grid lg:grid-cols-2 gap-8 md:gap-16 items-start">
      
      <div class="relative aspect-4/5 w-full overflow-hidden bg-brand-pink/5 border border-brand-purple/5 rounded-3xl shadow-xl animate-fast-up">
        <img 
          src={product.imagen} 
          alt={product.nombre} 
          class="w-full h-full object-cover"
          style={`view-transition-name: card-${product.id};`} 
        />
        <div class="absolute top-6 left-6 bg-white/90 backdrop-blur-md border border-brand-gold/20 px-4 py-1.5 rounded-full shadow-sm">
          <p class="text-[9px] font-bold text-brand-gold tracking-[0.2em] uppercase">{product.categoria}</p>
        </div>
      </div>

      <div class="flex flex-col space-y-8 md:pt-4">
        
        <header class="animate-fast-left">
          <div class="w-12 h-0.5 bg-brand-gold mb-6"></div>
          <h1 class="text-3xl md:text-5xl font-bold uppercase tracking-tight text-brand-purple leading-tight mb-4">
            {product.nombre}
          </h1>
          <span class="text-[10px] font-bold text-brand-purple/30 tracking-[0.4em] uppercase">Pieza Artesanal Exclusiva</span>
        </header>

        <div class="space-y-8 animate-fade-in" style="animation-delay: 150ms;">
          <div class="prose prose-slate">
            <p class="text-brand-purple/70 text-base md:text-lg font-light leading-relaxed max-w-md">
              {product.descripcion || "Cada pieza de Amuleto es diseñada para resaltar tu brillo natural. Joyería con alma, fabricada con los más altos estándares de calidad."}
            </p>
          </div>

          <div class="flex items-center gap-8 pt-6 border-t border-brand-purple/5">
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-brand-purple/30 uppercase tracking-widest mb-1">Precio</span>
              <span class="text-4xl md:text-5xl font-bold text-brand-purple tracking-tighter">${product.precio.toFixed(3)}</span>
            </div>
            <div class="h-14 w-px bg-brand-purple/10"></div>
            
          </div>
          
          <div class="pt-4">
            <button 
              id="add-to-cart-detail"
              class="w-full md:w-auto px-16 py-5 bg-brand-purple text-white font-bold uppercase text-xs tracking-[0.3em] rounded-2xl hover:bg-brand-gold transition-all duration-500 active:scale-95 shadow-lg shadow-brand-purple/10"
              data-product={productString}
            >
              Añadir al carrito
            </button>
          </div>
        </div>
      </div>
    </div>

    {relacionados.length > 0 && (
      <section class="mt-32 pt-16 border-t border-brand-purple/5 animate-fade-in" style="animation-delay: 450ms;">
        <div class="mb-12 flex flex-col items-center text-center">
            <h2 class="text-[10px] font-bold uppercase tracking-[0.6em] text-brand-purple/30 mb-4">Completa tu Look</h2>
            <div class="h-1 w-12 bg-brand-gold/30"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
          {relacionados.map((item) => <ProductCard {...item} />)}
        </div>
      </section>
    )}
  </main>
</CatalogLayout>

<script>
  import { addToCart } from '../../../store/cartStore';

  const initDetail = () => {
    const addBtn = document.getElementById('add-to-cart-detail');
    
    if (addBtn) {
      addBtn.onclick = () => {
        const productData = JSON.parse(addBtn.dataset.product || '{}');
        
        // Agregar al store silenciosamente
        addToCart(productData);

        // Feedback visual en el botón
        const originalText = addBtn.innerText;
        addBtn.innerText = "¡AÑADIDO!";
        addBtn.classList.replace('bg-brand-purple', 'bg-brand-gold');
        
        setTimeout(() => {
          addBtn.innerText = originalText;
          addBtn.classList.replace('bg-brand-gold', 'bg-brand-purple');
        }, 1500);
      };
    }
  };

  document.addEventListener('astro:page-load', initDetail);
  initDetail();
</script>

<style>
  .animate-fast-up { animation: quickUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fast-left { animation: quickLeft 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fade-in { animation: quickFade 0.8s ease-out both; }

  @keyframes quickUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes quickLeft {
    from { transform: translateX(-20px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  @keyframes quickFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>