<nav class="fixed top-0 w-full z-50 bg-[#08090d]/80 backdrop-blur-md border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
    <a href="/" class="font-black italic text-xl tracking-tighter hover:text-neon-green transition-colors">
      MIDNIGHT<span class="text-neon-green">STUDIO</span>
    </a>

    <button id="cart-trigger" class="relative p-3 bg-white/5 hover:bg-neon-green/10 border border-white/10 transition-all rounded-sm group">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-neon-green">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
        <path d="M3 6h18"></path>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      <span id="cart-counter" class="absolute -top-1 -right-1 bg-neon-green text-black font-mono font-bold text-[10px] w-5 h-5 flex items-center justify-center rounded-full scale-0 transition-transform">0</span>
    </button>
  </div>
</nav>

<script>
  import { cartItems, isCartOpen } from '../../store/cartStore';

  const counter = document.getElementById('cart-counter');
  const trigger = document.getElementById('cart-trigger');

  // Actualizar contador
  cartItems.subscribe(items => {
    const total = items.reduce((acc, item) => acc + item.cantidad, 0);
    if (counter) {
      counter.textContent = total.toString();
      total > 0 ? counter.classList.add('scale-100') : counter.classList.remove('scale-100');
    }
  });

  // Abrir carrito solo al click
  trigger?.addEventListener('click', () => isCartOpen.set(true));
</script>