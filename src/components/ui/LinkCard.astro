---
interface Props {
  title: string;
  href: string;
  colorClass?: string;
}

const { title, href, colorClass = "border-brand-purple" } = Astro.props;
---

<a 
  href={href}
  class={`link-luxury group relative flex items-center w-full 
          p-4 md:p-5 rounded-2xl border-l-[3px] 
          bg-white transition-all duration-500 overflow-hidden 
          ${colorClass}`}
>
  <div class="relative z-20 mr-4 transition-all duration-300">
    <div class="p-2.5 rounded-xl bg-transparent transition-all duration-500">
        <slot name="icon" />
    </div>
  </div>

  <span class="relative z-20 font-bold text-[10px] md:text-[11px] tracking-[0.2em] uppercase flex-1 leading-relaxed text-brand-purple transition-colors duration-300">
    {title}
  </span>

  <div class="relative z-20 ml-2 opacity-20 transition-all duration-500 text-brand-purple">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M9 18l6-6-6-6"/>
    </svg>
  </div>
</a>

<style>
  .link-luxury {
    -webkit-tap-highlight-color: transparent;
    /* Sombra base sutil */
    box-shadow: 0 4px 15px -1px rgba(59, 27, 84, 0.06);
    /* Bordes sutiles para definición en fondo claro */
    border-top: 1px solid rgba(59, 27, 84, 0.02);
    border-right: 1px solid rgba(59, 27, 84, 0.02);
    border-bottom: 1px solid rgba(59, 27, 84, 0.02);
    text-decoration: none;
  }
  
  .link-luxury span {
    white-space: nowrap;
  }
</style>