---
interface Props {
  title: string;
}
const { title } = Astro.props;

import "../styles/global.css";
import "toastify-js/src/toastify.css";
import { ClientRouter } from "astro:transitions";
import CartDrawer from "../components/cart/CartDrawer.astro";
import CatalogHeader from "../components/ui/CatalogHeader.astro";
import Footer from "../components/ui/Footer.astro";
---

<!doctype html>
<html lang="es" class="bg-[#fdf2f2]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/images/logocircular.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-[#fdf2f2] text-brand-purple selection:bg-brand-gold selection:text-white min-h-dvh flex flex-col relative overflow-x-hidden antialiased">
    
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute inset-0 bg-linear-to-b from-[#fff5f5] via-[#fdf2f2] to-[#fce8e8]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(59,27,84,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(59,27,84,0.02)_1px,transparent_1px)] bg-size-[35px_35px] opacity-30"></div>
    </div>

    <CatalogHeader />
    <CartDrawer />

    <main class="relative z-10 flex-1 flex flex-col">
      <slot />
    </main>

    <Footer />

<script>
  import Toastify from "toastify-js";
  import { addToCart } from "../store/cartStore";

  declare global {
    interface Window {
      amuletoToast: (message: string, type?: "success" | "error" | "warning") => void;
      __amuletoListenerActive?: boolean; // Bandera para evitar registros dobles
    }
  }

  function showAmuletoToast(message: string, type: "success" | "error" | "warning" = "success") {
    const colors = { success: "#d4af37", error: "#d69e9e", warning: "#3b1b54" };
    document.querySelectorAll(".toastify").forEach(t => t.remove());

    Toastify({
      text: message.toUpperCase(),
      duration: 2500,
      gravity: "bottom",
      position: "center",
      className: "amuleto-alert",
      style: {
        background: "white",
        color: "#3b1b54",
        border: `1px solid ${colors[type]}44`,
        boxShadow: "0 10px 30px -5px rgba(59, 27, 84, 0.1)"
      },
    }).showToast();
  }

  // Mantenemos esta función fuera para que la referencia sea estática
  const handlePurchase = (e: MouseEvent) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.add-to-cart-btn');

    if (btn) {
      e.preventDefault();
      e.stopImmediatePropagation(); // Detiene otros scripts en seco

      const productData = btn.getAttribute('data-product');
      if (productData) {
        try {
          const product = JSON.parse(productData);
          addToCart(product);
          showAmuletoToast(`${product.nombre} añadido`, "success");
        } catch (err) {
          console.error("Error:", err);
        }
      }
    }
  };

  const initSystem = () => {
    window.amuletoToast = showAmuletoToast;
    
    // Solo registramos el evento una vez en la vida de la ventana
    if (!window.__amuletoListenerActive) {
      document.addEventListener('click', handlePurchase, { capture: true });
      window.__amuletoListenerActive = true;
    }
    
    document.dispatchEvent(new CustomEvent('amuleto:refresh-ui'));
  };

  // Astro Page Load es suficiente
  document.addEventListener("astro:page-load", initSystem);
</script>

    <style is:global>
      /* Transiciones de Página Lentas y Suaves */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.4s;
        background: #fdf2f2 !important;
      }

      /* Toasts Minimalistas estilo cápsula */
      .amuleto-alert {
        font-family: inherit !important;
        font-size: 11px !important;
        font-weight: 700 !important;
        border-radius: 1.25rem !important;
        padding: 14px 26px !important;
        letter-spacing: 0.15em !important;
        backdrop-filter: blur(8px);
        z-index: 99999 !important;
        margin-bottom: 40px !important;
        text-align: center;
      }

      html, body { 
        margin: 0; 
        padding: 0; 
        height: 100%; 
        background-color: #fdf2f2; 
        color: #3b1b54;
      }

      /* Scrollbar Fino y Dorado */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: #fdf2f2; }
      ::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.2); border-radius: 20px; }
      ::-webkit-scrollbar-thumb:hover { background: #d4af37; }
    </style>
  </body>
</html>