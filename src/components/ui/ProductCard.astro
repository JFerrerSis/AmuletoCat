---
// src/components/ui/ProductCard.astro
import type { Product } from '../../types/product'; 

interface Props extends Product {}
const { id, nombre, precio, imagen, categoria } = Astro.props;

const productData = JSON.stringify({ id, nombre, precio, imagen, categoria });
---

<div class="group relative bg-white backdrop-blur-sm border border-brand-purple/5 p-4 md:p-6 rounded-4xl transition-all duration-700 ease-out flex flex-col h-full hover:shadow-[0_20px_50px_rgba(59,27,84,0.06)] hover:-translate-y-1.5 hover:bg-white/90">
  
  <a href={`/catalogo/producto/${id}`} class="absolute inset-0 z-10" aria-label={`Ver detalles de ${nombre}`}></a>

  <div class="relative aspect-square mb-4 md:mb-6 overflow-hidden bg-[#fdf2f2] rounded-3xl shrink-0">
    <img 
      src={imagen} 
      alt={nombre} 
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-1000 ease-in-out group-hover:scale-110"
      style={`view-transition-name: card-${id};`} 
    />
    
    <div class="absolute top-3 left-3 bg-white/80 backdrop-blur-md px-3 py-1 rounded-full z-20 shadow-sm border border-brand-purple/5">
      <p class="text-[8px] md:text-[9px] font-bold text-brand-purple tracking-[0.2em] uppercase">
        {categoria}
      </p>
    </div>
  </div>

  <div class="flex flex-col flex-1 relative z-20 px-1">
    <h3 class="text-sm md:text-base font-bold text-brand-purple tracking-wide uppercase leading-snug group-hover:text-brand-gold transition-colors duration-500 line-clamp-2 min-h-10">
      {nombre}
    </h3>
    
    <div class="w-8 h-[1.5px] bg-brand-gold/30 my-3 group-hover:w-16 group-hover:bg-brand-gold/60 transition-all duration-700"></div>

    <div class="flex items-center justify-between mt-auto gap-2">
      <div class="flex flex-col">
        <span class="text-lg md:text-xl font-bold text-brand-purple tracking-tight">
          ${precio.toFixed(2)}
        </span>
      </div>
      
      <button 
        type="button"
        class="add-to-cart-btn relative z-30 bg-brand-purple text-white p-3.5 hover:bg-brand-gold transition-all duration-500 active:scale-90 shadow-lg shadow-brand-purple/10 flex items-center justify-center rounded-2xl group/btn"
        data-product={productData}
        aria-label="Añadir a la bolsa"
      >
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          width="18" 
          height="18" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round" 
          class="transition-transform group-hover/btn:scale-110"
        >
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
          <path d="M3 6h18"></path>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>