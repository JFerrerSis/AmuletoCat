---
import CatalogLayout from '../layouts/CatalogoLayout.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import ProductSkeleton from '../components/ui/ProductSkeleton.astro'; 
import productosData from '../data/productos.json'; 
import type { Product } from '../types/product';

const products = (productosData as Product[]);
const categories = ["TODOS", ...new Set(products.map(p => p.categoria.toUpperCase()))];
const subcategories = [...new Set(products.map(p => p.subcategoria?.toUpperCase()).filter(Boolean))];
---

<CatalogLayout title="Catálogo | Amuleto">
  <main class="max-w-7xl mx-auto px-4 md:px-6 pt-24 md:pt-32 pb-24 relative">
    
    <header class="mb-12 md:mb-20 text-center animate-reveal">
      <h1 class="text-3xl md:text-5xl font-bold tracking-[0.25em] uppercase text-brand-purple mb-4">
        Amuletos<br/>
      </h1>
      <div class="w-12 h-0.5 bg-brand-gold mx-auto opacity-50"></div>
    </header>

    <nav class="flex flex-wrap justify-center gap-4 md:gap-12 mb-8 animate-reveal" style="animation-delay: 0.1s">
      {categories.map((cat) => (
        <button 
          class="filter-btn group relative py-2 transition-all duration-500"
          data-category={cat}
        >
          <span class="relative z-10 font-bold text-[10px] md:text-[11px] text-brand-purple/40 group-hover:text-brand-purple transition-colors uppercase tracking-[0.3em]">
            {cat}
          </span>
          <div class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-500 group-[.active]:w-full opacity-60"></div>
        </button>
      ))}
    </nav>

    <div 
      id="sub-filter-container" 
      class="hidden flex-wrap justify-center gap-x-8 gap-y-3 mb-16 border-t border-brand-purple/5 pt-8 transition-all duration-700 overflow-hidden"
    >
      <button 
        class="sub-filter-btn active-sub text-[9px] tracking-[0.25em] font-bold text-brand-purple/30 uppercase hover:text-brand-gold transition-colors cursor-pointer" 
        data-subcategory="TODAS"
      >
        Todas las Piezas
      </button>
      {subcategories.map((sub) => (
        <button 
          class="sub-filter-btn text-[9px] tracking-[0.25em] font-bold text-brand-purple/30 uppercase hover:text-brand-gold transition-colors cursor-pointer"
          data-subcategory={sub}
        >
          {sub}
        </button>
      ))}
    </div>

    <div id="product-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-x-8 md:gap-y-16">
      {Array.from({ length: 8 }).map(() => (
        <div class="skeleton-wrapper hidden-instant">
          <ProductSkeleton />
        </div>
      ))}

      {products.map((item, index) => (
        <div 
          class="product-item opacity-0 animate-reveal" 
          data-category={item.categoria.toUpperCase()}
          data-subcategory={item.subcategoria?.toUpperCase() || ''}
          data-name={item.nombre.toUpperCase()} 
          style={`animation-delay: ${0.2 + (index * 0.05)}s;`} 
        >
          <ProductCard {...item} />
        </div>
      ))}
    </div>
  </main>
</CatalogLayout>

<script>
  const initFilters = () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const subButtons = document.querySelectorAll('.sub-filter-btn');
    const subContainer = document.getElementById('sub-filter-container');
    const items = document.querySelectorAll('.product-item');
    const skeletons = document.querySelectorAll('.skeleton-wrapper');

    let currentMainCat = 'TODOS';
    let currentSubCat = 'TODAS';
    let currentSearch = ''; // Estado para la búsqueda

    const applyFilters = () => {
      items.forEach((item) => {
        const itemCat = item.getAttribute('data-category');
        const itemSub = item.getAttribute('data-subcategory');
        const itemName = item.getAttribute('data-name') || '';

        const matchesMain = currentMainCat === 'TODOS' || itemCat === currentMainCat;
        const matchesSub = currentSubCat === 'TODAS' || itemSub === currentSubCat;
        const matchesSearch = itemName.includes(currentSearch);

        if (matchesMain && matchesSub && matchesSearch) {
          item.classList.remove('hidden-instant');
        } else {
          item.classList.add('hidden-instant');
        }
      });
      skeletons.forEach(s => s.classList.add('hidden-instant'));
    };

    // Escuchar el buscador del Nav
    window.addEventListener('catalog:search', (e: any) => {
      currentSearch = e.detail || '';
      applyFilters();
    });

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        currentMainCat = btn.getAttribute('data-category') || 'TODOS';
        currentSubCat = 'TODAS';
        
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        if (currentMainCat === 'PULSERAS') {
          subContainer?.classList.remove('hidden');
          subContainer?.classList.add('flex');
          setTimeout(() => {
            subContainer?.classList.add('is-visible');
          }, 10);
        } else {
          subContainer?.classList.remove('is-visible');
          setTimeout(() => {
            subContainer?.classList.add('hidden');
            subContainer?.classList.remove('flex');
          }, 500);
        }

        subButtons.forEach(sb => sb.classList.remove('active-sub'));
        subButtons[0]?.classList.add('active-sub');
        applyFilters();
      });
    });

    subButtons.forEach(sb => {
      sb.addEventListener('click', () => {
        currentSubCat = sb.getAttribute('data-subcategory') || 'TODAS';
        subButtons.forEach(b => b.classList.remove('active-sub'));
        sb.classList.add('active-sub');
        applyFilters();
      });
    });

    buttons[0]?.classList.add('active');
  };

  document.addEventListener('astro:page-load', initFilters);
</script>

<style is:global>
  @keyframes reveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-reveal { animation: reveal 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  .hidden-instant { display: none !important; }

  #sub-filter-container {
    max-height: 0;
    opacity: 0;
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }

  #sub-filter-container.is-visible {
    max-height: 200px;
    opacity: 1;
  }

  .filter-btn.active span { 
    color: #3b1b54 !important;
    letter-spacing: 0.4em !important;
  }

  .sub-filter-btn {
    position: relative;
    padding-bottom: 4px;
    transition: all 0.4s ease;
  }

  .active-sub {
    color: #3b1b54 !important;
    opacity: 1 !important;
  }

  .active-sub::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    width: 60%;
    height: 1px;
    background: #d4af37;
  }
</style>