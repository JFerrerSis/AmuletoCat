<div id="tsparticles"></div>

<script>
  import { tsParticles } from "tsparticles-engine";
  import { loadSlim } from "tsparticles-slim";

  async function initParticles() {
    const container = document.getElementById("tsparticles");
    if (!container || container.hasChildNodes()) return;

    await loadSlim(tsParticles);

    await tsParticles.load("tsparticles", {
      fullScreen: { enable: false },
      fpsLimit: 60,
      particles: {
        // MEZCLA DE ESTRELLAS: Oro y Rosa Oscuro Intenso
        color: { 
          // Eliminamos el blanco. Usamos Oro Amuleto y un Rosa Fucsia/Magenta oscuro
          value: ["#d4af37", "#a01050", "#c71585"] 
        },
        move: {
          enable: true,
          speed: 0.25, // Un pelín más rápido para que se note la mezcla
          direction: "none",
          random: true,
          straight: false,
          outModes: { default: "out" },
        },
        number: {
          value: 90, 
          density: { enable: true, area: 800 },
        },
        opacity: { 
          // Aumentamos la opacidad mínima para que los colores oscuros no se pierdan
          value: { min: 0.3, max: 0.8 }, 
          anim: {
            enable: true,
            speed: 1,
            sync: false
          }
        },
        shape: { type: "star" },
        size: { 
          value: { min: 1, max: 2 }, // Ligeramente más grandes para apreciar el color
        },
      },
      detectRetina: true,
    });
  }

  document.addEventListener('astro:page-load', initParticles);
</script>

<style>
  #tsparticles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    /* MANTENEMOS EL FONDO ROSADO ACTUAL */
    background: transparent;
    pointer-events: none; 
  }
</style>