---
interface Props {
  title: string;
}
const { title } = Astro.props;

import "../styles/global.css";
import "toastify-js/src/toastify.css";
import { ClientRouter } from "astro:transitions";
import CartDrawer from "../components/cart/CartDrawer.astro";
import CatalogHeader from "../components/ui/CatalogHeader.astro";
import Footer from "../components/ui/Footer.astro";
---

<!doctype html>
<html lang="es" class="bg-[#08090d]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/logodark.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-[#08090d] text-white selection:bg-neon-green selection:text-black min-h-dvh flex flex-col relative overflow-x-hidden">
    
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(0,245,212,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(0,245,212,0.02)_1px,transparent_1px)] bg-size[40px_40px]"></div>
      <div class="absolute inset-0 bg-radial-at-t from-neon-green/5 to-transparent"></div>
    </div>

    <CatalogHeader />
    <CartDrawer />

    <main class="relative z-10 flex-1 flex flex-col">
      <slot />
    </main>

    <Footer />

<script>
  import Toastify from "toastify-js";
  import { addProductToCart } from "../store/cartStore";

  // 1. Sistema de Notificaciones
  function showMidnightToast(message: string, type: "success" | "error" | "warning" = "success") {
    const colors = { success: "#00f5d4", error: "#ff4b2b", warning: "#facc15" };
    // Evitar acumulación de toasts en transiciones rápidas
    document.querySelectorAll(".toastify").forEach(t => t.remove());

    Toastify({
      text: `// ${message.toUpperCase()}`,
      duration: 2000,
      gravity: "bottom",
      position: "right",
      className: "midnight-alert",
      style: {
        background: "#08090d",
        color: colors[type],
        border: `1px solid ${colors[type]}33`,
      },
    }).showToast();
  }

  // 2. Manejador Global de Compras
  const handleGlobalPurchase = (e: MouseEvent) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.add-to-cart-btn');

    if (btn) {
      e.preventDefault();
      e.stopPropagation();

      const productData = btn.getAttribute('data-product');
      if (productData) {
        try {
          const product = JSON.parse(productData);
          addProductToCart(product);
          showMidnightToast(`${product.nombre} ADQUIRIDO`, "success");
        } catch (err) {
          console.error("Error al procesar producto:", err);
        }
      }
    }
  };

  // 3. Reinicio de Componentes (Header y Carrito)
  const refreshComponentLogic = () => {
    // Buscamos botones de toggle que hayan perdido su listener
    const cartToggle = document.querySelector('.cart-toggle-btn');
    const mobileMenuBtn = document.querySelector('.mobile-menu-btn');

    // Aquí disparamos un evento personalizado que tus componentes 
    // Header y CartDrawer deben escuchar para re-inicializarse
    document.dispatchEvent(new CustomEvent('midnight:refresh-ui'));
    
    // Si el Header tiene lógica simple de clases, la reforzamos aquí
    console.log("Sistema UI Re-conectado");
  };

  const initSystem = () => {
    window.midnightToast = showMidnightToast;

    // Limpieza de listeners globales para evitar duplicados
    document.removeEventListener('click', handleGlobalPurchase, true);
    document.addEventListener('click', handleGlobalPurchase, true);

    refreshComponentLogic();

    if (!sessionStorage.getItem("midnight_auth")) {
      setTimeout(() => window.midnightToast?.("SISTEMA CONECTADO", "success"), 800);
      sessionStorage.setItem("midnight_auth", "true");
    }
  };

  // Escuchar todos los eventos de ciclo de vida de Astro
  document.addEventListener("astro:page-load", initSystem);
  document.addEventListener("astro:after-swap", initSystem);

  // Ejecución inmediata para el primer renderizado
  initSystem();
</script>
    <style is:global>
      /* View Transitions Fix */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.3s;
        background: #08090d !important;
      }

      .midnight-alert {
        font-family: "JetBrains Mono", monospace !important;
        font-size: 10px !important;
        font-weight: 800 !important;
        border-radius: 0px !important;
        padding: 12px 20px !important;
        letter-spacing: 0.1em !important;
        backdrop-filter: blur(10px);
        z-index: 99999 !important;
        margin-bottom: 20px !important;
      }

      html, body { margin: 0; padding: 0; height: 100%; background-color: #08090d; }

      /* Scrollbar Custom */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: #08090d; }
      ::-webkit-scrollbar-thumb { background: rgba(0, 245, 212, 0.2); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: #00f5d4; }
    </style>
  </body>
</html>