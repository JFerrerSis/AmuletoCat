<div id="tsparticles"></div>

<script>
  import { tsParticles } from "tsparticles-engine";
  import { loadSlim } from "tsparticles-slim";

  async function initParticles() {
    // Evitamos duplicados en las transiciones
    const container = document.getElementById("tsparticles");
    if (!container || container.hasChildNodes()) return;

    await loadSlim(tsParticles);

    await tsParticles.load("tsparticles", {
      fullScreen: { enable: false },
      fpsLimit: 60,
      interactivity: {
        events: {
          onHover: {
            enable: true,
            mode: "grab",
          },
          onClick: {
            enable: false,
          },
        },
        modes: {
          grab: {
            distance: 180,
            links: { 
              opacity: 0.3, 
              color: "#00f5d4" 
            },
          },
        },
      },
      particles: {
        // Mezcla de colores: Cian neón y Azul profundo de medianoche
        color: { 
          value: ["#00f5d4", "#1e1b4b", "#312e81", "#ffffff"] 
        },
        links: {
          color: "#00f5d4",
          distance: 150,
          enable: true,
          opacity: 0.1, // Líneas muy tenues para que no ensucien la "noche"
          width: 0.5,
        },
        move: {
          enable: true,
          speed: 0.5, // Movimiento lento, casi estático como el cielo
          random: true,
          straight: false,
          outModes: { default: "out" },
        },
        number: {
          value: 100, // Un poco más para simular densidad estelar
          density: { enable: true, area: 800 },
        },
        opacity: { 
          value: { min: 0.1, max: 0.6 },
          random: true,
          anim: {
            enable: true,
            speed: 1,
            opacity_min: 0.1,
            sync: false
          }
        },
        shape: { type: "star" },
        size: { 
          value: { min: 1, max: 4 }, // Tamaños variados para profundidad
          random: true 
        },
      },
      detectRetina: true,
    });
  }

  document.addEventListener('astro:page-load', initParticles);
</script>

<style>
  #tsparticles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    /* Degradado de fondo para reforzar la sensación de medianoche */
    background: radial-gradient(circle at center, #0a0a0f 0%, #000000 100%);
    pointer-events: none; 
  }
</style>
