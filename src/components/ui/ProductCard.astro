---
// src/components/ui/ProductCard.astro
import type { Product } from '../../types/product'; 

interface Props extends Product {}
const { id, nombre, precio, imagen, categoria } = Astro.props;

// Pre-calculamos el string para evitar lógica pesada en el render
const productData = JSON.stringify({ id, nombre, precio, imagen, categoria });
---

<div class="group relative bg-[#0d0e12]/90 border border-white/5 p-3 md:p-5 rounded-sm hover:border-neon-green/40 transition-all duration-500 shadow-2xl overflow-hidden flex flex-col h-full hover:shadow-[0_12px_40px_rgba(0,0,0,0.7)]">
  
  <a href={`/catalogo/producto/${id}`} class="absolute inset-0 z-10" aria-label={`Ver detalles de ${nombre}`}></a>

  <div class="absolute inset-0 bg-linear-to-b from-transparent via-neon-green/10 to-transparent -translate-y-full group-hover:animate-scan pointer-events-none z-0 opacity-0 group-hover:opacity-100"></div>

  <div class="relative aspect-square mb-3 md:mb-5 overflow-hidden bg-black/60 border border-white/5 rounded-sm shrink-0">
    <img 
      src={imagen} 
      alt={nombre} 
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
      style={`view-transition-name: card-${id};`} 
    />
    
    <div class="absolute top-0 left-0 bg-black/90 border-b border-r border-neon-green/30 px-2 py-1 z-20">
      <p class="text-[6px] md:text-[8px] font-mono text-neon-green tracking-[0.2em] uppercase font-bold italic">
        {categoria}
      </p>
    </div>
  </div>

  <div class="flex flex-col flex-1 relative z-20">
    <h3 class="text-sm md:text-base lg:text-lg font-black text-white italic uppercase tracking-tighter leading-tight group-hover:text-neon-green transition-colors line-clamp-2 min-h-10 md:min-h-12">
      {nombre}
    </h3>
    
    <div class="flex items-center justify-between pt-3 border-t border-white/5 mt-auto gap-2">
      <div class="flex flex-col">
        <span class="text-[9px] font-mono text-white/30 uppercase tracking-widest leading-none mb-1">Precio</span>
        <span class="text-base md:text-xl font-mono font-bold text-white tracking-tighter">
          ${precio.toFixed(2)}
        </span>
      </div>
      
      <button 
  type="button"
  class="add-to-cart-btn relative z-30 bg-neon-green text-black p-2.5 md:p-3 hover:bg-white transition-all active:scale-90 shadow-[0_0_15px_rgba(0,245,212,0.1)] flex items-center justify-center rounded-sm group/btn"
  data-product={productData}
  aria-label="Añadir al carrito"
>
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    width="18" 
    height="18" 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2.5" 
    stroke-linecap="round" 
    stroke-linejoin="round" 
    class="transition-transform group-hover/btn:scale-110"
  >
    <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
    <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.1-5.38a.5.5 0 0 0-.5-.62H7.5"/>
  </svg>
</button>
      </button>
    </div>
  </div>
</div>

<style>
  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
  .animate-scan {
    animation: scan 3s linear infinite;
  }
  
  /* Soporte para truncado de texto en navegadores antiguos */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>