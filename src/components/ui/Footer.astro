---
const year = new Date().getFullYear();
// Configuración de links
const githubUrl = "https://github.com/JFerrerSis"; 
const instagramUrl = "https://www.instagram.com/jferr3r?igsh=ZDVjenVwcGNqM3pv";
const linkedinUrl = "https://www.linkedin.com/in/jorge-ferrer-8a167930b?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=android_app"; // <-- Agrega tu perfil aquí
const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER;
const whatsappUrl = `https://wa.me/${phone}`;
---

<footer class="w-full pb-10 pt-6 text-center font-mono uppercase italic border-t border-white/5 bg-black/20 backdrop-blur-sm relative z-20">
  <div class="max-w-6xl mx-auto px-6 flex flex-col items-center gap-4">
    
    <div class="flex items-center gap-6 mb-2">
      <a href={githubUrl} target="_blank" class="text-white/20 hover:text-neon-green transition-all hover:scale-110" title="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>

      <a href={linkedinUrl} target="_blank" class="text-white/20 hover:text-[#0077b5] transition-all hover:scale-110" title="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
      </a>

      <a href={instagramUrl} target="_blank" class="text-white/20 hover:text-neon-pink transition-all hover:scale-110" title="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    </div>

    <div class="space-y-1">
      <p class="text-[9px] md:text-[10px] text-neon-green font-black tracking-[0.3em] opacity-80">
        CREATED_BY: <a href={githubUrl} target="_blank" class="text-white hover:underline decoration-neon-green underline-offset-4">J. FERRER</a> 
        <span class="text-white/20 mx-2">//</span> 
        <span class="text-white/40">FULL-STACK_DEV</span>
      </p>
      
      <p class="text-[7px] text-white/20 tracking-[0.6em] font-light">
        EST {year} <span class="mx-1">/</span> MARACAIBO <span class="mx-1">/</span> VENEZUELA
      </p>
    </div>

    <div class="h-px w-12 bg-neon-green/20"></div>
  </div>
</footer>