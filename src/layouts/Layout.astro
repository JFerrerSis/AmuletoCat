---
interface Props { title: string; }
const { title } = Astro.props;
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css'; 
import "toastify-js/src/toastify.css"; 
import Footer from '../components/ui/Footer.astro';
---

<!DOCTYPE html>
<html lang="es" class="overflow-hidden h-full fixed inset-0"> 
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/logo.png" />
    <title>{title}</title>
    <ClientRouter />
</head>

<body class="bg-[#fdf2f2] text-brand-purple selection:bg-brand-gold selection:text-white h-full w-full fixed inset-0 overflow-hidden flex flex-col font-light antialiased touch-pan-y">
    
    <div class="fixed inset-0 pointer-events-none z-0">
      
      <div class="absolute inset-0 bg-linear-to-b from-[#fff5f5] via-[#fdf2f2] to-[#fce8e8]"></div>
      
      <div class="absolute inset-0 bg-[linear-gradient(rgba(59,27,84,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,27,84,0.03)_1px,transparent_1px)] bg-size-[35px_35px] opacity-40"></div>
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[80%] bg-brand-pink/10 rounded-full blur-[120px]"></div>

      <div id="sakura-container" class="absolute inset-0 overflow-hidden pointer-events-none"></div>
    </div>
        
    <main class="relative z-10 flex-1 w-full flex flex-col items-center overflow-hidden">
      <slot />
    </main>

    <Footer class="relative z-20" />

    <script>
      const createPetal = () => {
        const container = document.getElementById('sakura-container');
        if (!container || container.childElementCount > 20) return; 

        const petal = document.createElement('div');
        petal.classList.add('petal');
        
        const size = Math.random() * 7 + 5 + 'px';
        const left = Math.random() * 100 + '%';
        const duration = Math.random() * 6 + 8 + 's'; // Caída lenta y elegante
        const delay = Math.random() * 5 + 's';

        petal.style.width = size;
        petal.style.height = size;
        petal.style.left = left;
        petal.style.animationDuration = duration;
        petal.style.animationDelay = delay;
        
        container.appendChild(petal);

        setTimeout(() => petal.remove(), (parseFloat(duration) + parseFloat(delay)) * 1000);
      };

      // Intervalo más espaciado para que no sature visualmente
      setInterval(createPetal, 400);
    </script>

    <style is:global>
      /* Reset y Bloqueo de Scroll */
      html, body {
        overflow: hidden !important;
        height: 100% !important;
        height: 100dvh !important;
        width: 100% !important;
        position: fixed !important;
        overscroll-behavior: none !important;
        background-color: #fdf2f2 !important; 
      }

      body {
        margin: 0;
        padding: 0;
        -webkit-overflow-scrolling: none;
      }

      /* Animación de Pétalos de Sakura */
      .petal {
        position: absolute;
        top: -20px;
        background-color: #f0a9de; /* Rosado pétalo */
        border-radius: 15px 2px 15px 15px;
        opacity: 0;
        filter: blur(0.4px);
        animation: fall linear forwards;
        pointer-events: none;
        box-shadow: 0 0 4px rgba(234, 167, 173, 0.1);
      }

      @keyframes fall {
        0% {
          transform: translateY(0) translateX(0) rotate(0deg);
          opacity: 0;
        }
        15% { opacity: 0.6; }
        90% { opacity: 0.3; }
        100% {
          transform: translateY(110vh) translateX(120px) rotate(540deg);
          opacity: 0;
        }
      }

      /* Scrollbar invisible pero funcional si fuera necesario */
      ::-webkit-scrollbar { display: none; }
    </style>
</body>
</html>