---
interface Props {
	href: string;
	title: string;
	description?: string;
	isPrimary?: boolean; // Para destacar el botón de Catálogo
}

const { href, title, description, isPrimary = false } = Astro.props;
---

<a 
	href={href}
	class={`group relative w-full p-4 rounded-2xl border transition-all duration-300 flex flex-col gap-1 
	${isPrimary 
		? "bg-white text-black border-white hover:bg-transparent hover:text-white" 
		: "bg-white/5 border-white/10 hover:border-purple-500/50 hover:bg-white/10"
	}`}
>
	<div class="flex justify-between items-center">
		<span class="font-bold tracking-tight text-lg">{title}</span>
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
	</div>
	{description && <span class={`text-sm ${isPrimary ? "opacity-70" : "text-gray-500"}`}>{description}</span>}
</a>