---
import CatalogLayout from '../layouts/CatalogoLayout.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import ProductSkeleton from '../components/ui/ProductSkeleton.astro'; 
import productosData from '../data/productos.json'; 
import type { Product } from '../types/product';

const products = (productosData as Product[]);
const categories = ["TODOS", ...new Set(products.map(p => p.categoria.toUpperCase()))];

// Helper para formatear a Peso Argentino (ARS)
const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0,
  }).format(amount);
};
---

<CatalogLayout title="Catálogo | Amuleto">
  <main class="max-w-7xl mx-auto px-4 md:px-6 pt-24 md:pt-32 pb-24 relative bg-brand-pink-0.5">
    
    <header class="mt-15 mb-12 md:mb-20 text-center animate-reveal">
      <h1 class="text-3xl md:text-5xl font-bold tracking-[0.25em] uppercase text-brand-purple mb-4">
        Amuletos<br/>
      </h1>
      <div class="w-12 h-0.5 bg-brand-gold mx-auto opacity-50"></div>
    </header>

    <div class="flex flex-wrap justify-center gap-2 md:gap-4 mb-12 md:mb-20 animate-reveal" style="animation-delay: 0.1s">
      {categories.map((cat) => (
        <button 
          class="filter-btn group relative px-4 md:px-8 py-3 transition-all duration-500"
          data-category={cat}
        >
          <span class="relative z-10 font-bold text-[10px] md:text-[11px] text-brand-purple/40 group-hover:text-brand-purple transition-colors uppercase tracking-[0.2em]">
            {cat}
          </span>
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-brand-gold transition-all duration-500 group-[.active]:w-8 opacity-80"></div>
        </button>
      ))}
    </div>

    <div id="product-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-x-8 md:gap-y-16">
      
      {Array.from({ length: 8 }).map((_, i) => (
        <div class="skeleton-wrapper hidden-instant">
          <ProductSkeleton />
        </div>
      ))}

      {products.map((item, index) => (
        <div 
          class="product-item opacity-0 animate-reveal" 
          data-category={item.categoria.toUpperCase()}
          style={`animation-delay: ${0.2 + (index * 0.05)}s;`} 
        >
          {/* Nota: Asegúrate de que tu componente ProductCard 
              también use Intl.NumberFormat para ARS internamente 
          */}
          <ProductCard {...item} />
        </div>
      ))}
    </div>
  </main>
</CatalogLayout>

<script>
  const initFilters = () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.product-item');
    const skeletons = document.querySelectorAll('.skeleton-wrapper');

    if (buttons.length === 0) return;

    const applyFilter = (category: string) => {
      items.forEach((item) => {
        const itemCat = item.getAttribute('data-category');
        const shouldShow = category === 'TODOS' || itemCat === category;
        
        const el = item as HTMLElement;
        el.style.animation = 'none';
        el.style.opacity = '1';

        if (shouldShow) {
          el.classList.remove('hidden-instant');
        } else {
          el.classList.add('hidden-instant');
        }
      });
      
      skeletons.forEach(s => s.classList.add('hidden-instant'));
    };

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category') || 'TODOS';
        
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Efecto de carga rápido
        items.forEach(i => i.classList.add('hidden-instant'));
        skeletons.forEach(s => s.classList.remove('hidden-instant'));

        setTimeout(() => {
          // @ts-ignore
          if (!document.startViewTransition) {
            applyFilter(category);
          } else {
            // @ts-ignore
            document.startViewTransition(() => applyFilter(category));
          }
        }, 150 )
      });
    });

    buttons[0]?.classList.add('active');
    skeletons.forEach(s => s.classList.add('hidden-instant'));
    items.forEach(i => i.classList.remove('hidden-instant'));
  };

  document.addEventListener('astro:page-load', initFilters);
</script>

<style is:global>
  @keyframes reveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-reveal { 
    animation: reveal 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; 
  }

  .hidden-instant { display: none !important; }

  .filter-btn.active span {
    color: #3b1b54 !important; /* brand-purple */
    letter-spacing: 0.3em;
  }

  .filter-btn.active div {
    width: 2rem !important;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.4s;
  }
</style>