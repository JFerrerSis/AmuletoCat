---
import { ShoppingCart } from 'lucide-astro'; // ShoppingBag suele verse más elegante para joyería
---

<nav 
  id="main-nav"
  class="fixed top-0 w-full z-50 transition-all duration-700 border-b border-transparent bg-brand-pink/0.5 backdrop-blur-md"
>
  <div class="max-w-7xl mx-auto px-6 h-24 flex justify-between items-center transition-all duration-500" id="nav-content">
    
    <a href="/" class="group flex items-center gap-4 transition-transform duration-500 hover:scale-105">
      <div class="relative w-20 h-20 flex items-center justify-center transition-all duration-500" id="logo-container">
        <div class="absolute inset-0 bg-brand-gold/15 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        
        <img 
          src="/images/LogoCatalogo.png" 
          alt="Amuleto" 
          class="relative z-10 w-full h-full object-contain filter drop-shadow-md group-hover:drop-shadow-[0_0_12px_rgba(212,175,55,0.4)] transition-all duration-500"
        />
      </div>
    </a>

    <button 
      id="cart-trigger" 
      class="relative p-3 bg-white/30 hover:bg-brand-gold/10 border border-brand-purple/10 transition-all rounded-2xl group backdrop-blur-sm"
    >
      <ShoppingCart 
        size={22}
        strokeWidth={1.5}
        class="text-brand-purple group-hover:text-brand-gold transition-colors duration-300"
      />
      
      <span 
        id="cart-counter" 
        class="absolute -top-1 -right-1 bg-brand-gold text-white font-bold text-[10px] w-5 h-5 flex items-center justify-center rounded-full scale-0 transition-transform shadow-sm border border-white"
      >
        0
      </span>
    </button>
  </div>
</nav>

<script>
  import { cartItems, isCartOpen } from '../../store/cartStore';

  const initHeader = () => {
    const counter = document.getElementById('cart-counter');
    const trigger = document.getElementById('cart-trigger');
    const nav = document.getElementById('main-nav');
    const navContent = document.getElementById('nav-content');
    const logoContainer = document.getElementById('logo-container');

    const handleScroll = () => {
      const isScrolled = window.scrollY > 30;
      
      if (isScrolled) {
        navContent?.classList.replace('h-24', 'h-16');
        logoContainer?.classList.replace('w-20', 'w-14');
        logoContainer?.classList.replace('h-20', 'h-14');
        nav?.classList.add('border-brand-purple/5', 'shadow-sm');
        nav?.classList.replace('bg-brand-pink/70', 'bg-brand-pink/85');
      } else {
        navContent?.classList.replace('h-16', 'h-24');
        logoContainer?.classList.replace('w-14', 'w-20');
        logoContainer?.classList.replace('h-14', 'h-20');
        nav?.classList.remove('border-brand-purple/5', 'shadow-sm');
        nav?.classList.replace('bg-brand-pink/85', 'bg-brand-pink/70');
      }
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll();

    cartItems.subscribe(items => {
      const total = items.reduce((acc, item) => acc + (item.cantidad || 0), 0);
      if (counter) {
        counter.textContent = total.toString();
        total > 0 ? counter.classList.add('scale-100') : counter.classList.remove('scale-100');
      }
    });

    if (trigger) {
      trigger.onclick = (e) => {
        e.preventDefault();
        isCartOpen.set(true);
      };
    }
  };

  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>

<style>
  .bg-brand-pink\/70 { background-color: rgba(214, 158, 158, 0.7); }
  .bg-brand-pink\/85 { background-color: rgba(214, 158, 158, 0.85); }

  #main-nav, #nav-content, #logo-container {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  img { image-rendering: -webkit-optimize-contrast; }
</style>