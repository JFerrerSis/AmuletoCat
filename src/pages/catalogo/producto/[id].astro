---
import CatalogLayout from '../../../layouts/CatalogoLayout.astro';
import ProductCard from '../../../components/ui/ProductCard.astro';
import productosData from '../../../data/productos.json'; 
import type { Product } from '../../../types/product';

export async function getStaticPaths() {
  const products = (productosData as Product[]);
  return products.map((product) => ({
    params: { id: product.id.toString() },
    props: { product },
  }));
}

const { product } = Astro.props;

const allProducts = (productosData as Product[]);
const relacionados = allProducts
  .filter(p => p.categoria === product.categoria && p.id !== product.id)
  .slice(0, 4);

const productString = JSON.stringify(product);
---

<CatalogLayout title={`${product.nombre} | MidNight Studio`}>
  <main class="max-w-6xl mx-auto px-6 pt-24 md:pt-32 pb-24 relative overflow-hidden contain-paint">
    
  <a 
  href="/catalogo" 
  data-astro-history="replace"
  data-astro-prefetch="viewport"
  class="inline-flex items-center gap-3 text-white/40 hover:text-neon-green transition-all font-mono text-[10px] uppercase italic mb-12 group tracking-widest animate-fade-in"
>
  <span class="group-hover:-translate-x-1 transition-transform bg-white/5 border border-white/10 px-2 py-1">←</span> 
  <span>Regresar al Catálogo</span>
</a>

    <div class="grid lg:grid-cols-2 gap-8 md:gap-16 items-start">
      
      <div class="relative aspect-square w-full overflow-hidden bg-black/40 border border-white/5 rounded shadow-2xl animate-fast-up">
        <img 
          src={product.imagen} 
          alt={product.nombre} 
          decoding="async"
          loading="eager"
          class="w-full h-full object-cover"
          style={`view-transition-name: card-${product.id};`} 
        />
        <div class="absolute top-4 left-4 bg-black/90 border border-neon-green/20 px-3 py-1">
          <p class="text-[8px] font-mono text-neon-green tracking-[0.3em] uppercase italic">{product.categoria}</p>
        </div>
      </div>

      <div class="flex flex-col space-y-8 md:pt-4">
        
        <header class="border-l-2 border-neon-green pl-6 md:pl-8 animate-fast-left">
          <h1 class="text-2xl md:text-4xl font-black italic uppercase tracking-tighter text-white leading-none mb-2">
            {product.nombre}
          </h1>
          <span class="text-[10px] font-mono text-white/20 tracking-[0.5em] uppercase italic">Especificaciones Técnicas</span>
        </header>

        <div class="space-y-8 animate-fade-in" style="animation-delay: 150ms;">
          <div class="prose prose-invert">
            <p class="text-white/60 text-sm md:text-lg font-light leading-relaxed max-w-md italic">
              {product.descripcion || "Diseño exclusivo de la colección MidNight Studio. Fabricación optimizada para máxima definición textil."}
            </p>
          </div>

          <div class="flex items-center gap-6 pt-4 border-t border-white/5">
            <div class="flex flex-col">
              <span class="text-[9px] font-mono text-white/30 uppercase tracking-widest mb-1">Precio Unitario</span>
              <span class="text-4xl md:text-5xl font-mono font-bold text-neon-green tracking-tighter italic">${product.precio.toFixed(2)}</span>
            </div>
            <div class="h-12 w-px bg-white/5"></div>
            <div class="flex flex-col">
              <span class="text-[9px] font-mono text-white/30 uppercase tracking-widest mb-1">Status</span>
              <span class="text-xs font-bold text-white uppercase italic bg-white/5 px-2 py-1 border border-white/10">Disponible</span>
            </div>
          </div>
          
          <div class="pt-4">
            <button 
              class="add-to-cart-btn w-full md:w-auto px-12 py-5 bg-neon-green text-black font-black uppercase italic text-xs tracking-[0.2em] hover:bg-white transition-all active:scale-95 shadow-[0_0_20px_rgba(0,245,212,0.2)]"
              data-product={productString}
            >
              Adquirir 
            </button>
          </div>
        </div>

        <div class="pt-8 grid grid-cols-2 gap-4 animate-fade-in" style="animation-delay: 300ms;">
            <div class="flex flex-col border-l border-white/10 pl-4 py-2">
                <span class="text-[7px] font-mono uppercase tracking-widest text-white/40">Colección</span>
                <span class="text-[10px] font-bold text-white uppercase italic">MidNight 2026</span>
            </div>
            <div class="flex flex-col border-l border-white/10 pl-4 py-2">
                <span class="text-[7px] font-mono uppercase tracking-widest text-white/40">Origen</span>
                <span class="text-[10px] font-bold text-white uppercase italic">Maracaibo, VZLA</span>
            </div>
        </div>
      </div>
    </div>

    {relacionados.length > 0 && (
      <section class="mt-32 pt-16 border-t border-white/5 animate-fade-in" style="animation-delay: 450ms;">
        <div class="mb-10 flex items-center justify-between">
            <h2 class="text-xs font-mono uppercase tracking-[0.5em] text-white/30 italic">Diseños Relacionados</h2>
            <div class="h-px flex-1 mx-8 bg-white/5"></div>
            <a href="/catalogo" class="text-[9px] font-mono text-neon-green uppercase tracking-widest hover:text-white transition-colors">Ver Todo</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {relacionados.map((item) => <ProductCard {...item} />)}
        </div>
      </section>
    )}
  </main>
</CatalogLayout>

<style is:global>
  /* Optimizaciones de Bajo Nivel */
  .animate-fast-up, .animate-fast-left, .animate-fade-in {
    will-change: transform, opacity;
    backface-visibility: hidden;
    transform: translate3d(0,0,0);
  }

  @keyframes quickUp {
    from { transform: translate3d(0, 12px, 0); opacity: 0; }
    to { transform: translate3d(0, 0, 0); opacity: 1; }
  }

  @keyframes quickLeft {
    from { transform: translate3d(-12px, 0, 0); opacity: 0; }
    to { transform: translate3d(0, 0, 0); opacity: 1; }
  }

  @keyframes quickFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-fast-up { animation: quickUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fast-left { animation: quickLeft 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
  .animate-fade-in { animation: quickFade 0.5s ease-out both; }

  /* Corregir View Transition para evitar el "salto" visual */
  ::view-transition-old(root), ::view-transition-new(root) {
    animation-duration: 0.2s;
  }
</style>