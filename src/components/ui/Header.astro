<header class="text-center relative px-4 pt-4 md:pt-10 z-20">
  <div class="relative inline-block">
    <div class="animate-entrance relative 
                w-40 h-40 
                md:w-56 md:h-56 
                flex items-center justify-center mx-auto">
      <div class="w-full h-full rounded-full overflow-hidden bg-white/50 backdrop-blur-sm">
        <img 
          src="/images/logo.jpeg" 
          alt="Amuleto Logo" 
          class="w-full h-full object-contain scale-90" 
        />
      </div>
    </div>
  </div>
</header>

<style is:global>
  @keyframes entrance {
    0% { 
      opacity: 0; 
      transform: scale(0.9) translateY(10px); 
    }
    100% { 
      opacity: 1; 
      transform: scale(1) translateY(0); 
    }
  }

  .animate-entrance { 
    animation: entrance 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; 
  }

  /* Ajuste para pantallas muy bajitas (iPhone SE o móviles en horizontal) */
  @media (max-height: 670px) {
    header { padding-top: 1rem; }
    .animate-entrance {
      width: 8rem; /* w-32 */
      height: 8rem;
    }
  }
</style>