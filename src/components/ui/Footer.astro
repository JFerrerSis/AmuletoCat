---
// Importamos la versión directamente desde el package.json
import { version } from '../../../package.json';

const year = new Date().getFullYear();
const githubUrl = "https://github.com/JFerrerSis"; 
const instagramUrl = "https://www.instagram.com/jferr3r?igsh=ZDVjenVwcGNqM3pv";
const linkedinUrl = "https://www.linkedin.com/in/jorge-ferrer-8a167930b?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=android_app";
---

<footer class="w-full pb-12 pt-10 text-center font-mono uppercase italic border-t border-white/5 bg-black/20 backdrop-blur-sm relative z-20">
  <div class="max-w-6xl mx-auto px-6 flex flex-col items-center gap-6">
    
    <div class="flex items-center gap-8 mb-2">
      <a href={githubUrl} target="_blank" class="text-white/20 hover:text-neon-green transition-all hover:scale-125 hover:drop-shadow-[0_0_10px_#00ff66] neon-flicker" title="GitHub">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>

      <a href={linkedinUrl} target="_blank" class="text-white/20 hover:text-neon-green transition-all hover:scale-125 hover:drop-shadow-[0_0_10px_#00f5d4] neon-flicker-delayed" title="LinkedIn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
      </a>

      <a href={instagramUrl} target="_blank" class="text-white/20 hover:text-neon-pink transition-all hover:scale-125 hover:drop-shadow-[0_0_10px_#ff00ff] neon-flicker" title="Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    </div>

    <div class="space-y-4">
      <p class="text-[14px] md:text-[16px] text-neon-green font-black tracking-[0.4em] opacity-90">
        CREATED_BY: <a href={githubUrl} target="_blank" class="text-white hover:underline decoration-neon-green underline-offset-8">J. FERRER</a> 
        <span class="text-white/20 mx-3">//</span> 
        <span class="text-white/40">FULL-STACK_DEV</span>
      </p>
      
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <p class="text-[10px] text-white/30 tracking-[0.5em] font-medium">
          EST {year} <span class="mx-2 text-white/10">/</span> MARACAIBO <span class="mx-2 text-white/10">/</span> VENEZUELA
        </p>
        
        <span class="px-3 py-1 bg-neon-green/5 border border-neon-green/20 text-[11px] text-neon-green rounded-full tracking-[0.2em] font-bold not-italic shadow-[0_0_15px_rgba(0,245,212,0.1)]">
          V{version}
        </span>
      </div>
    </div>

    <div class="h-px w-24 bg-linear-to-r from-transparent via-neon-green/30 to-transparent"></div>
  </div>
</footer>

<style>
  @keyframes flicker {
    0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }
    20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }
  }
  .neon-flicker:hover { animation: flicker 2s infinite step-end; }
  .neon-flicker-delayed:hover { animation: flicker 3s infinite step-end; animation-delay: 0.5s; }
</style>