---
// src/components/ui/ProductCard.astro
import type { Product } from '../../types/product'; 
import { ShoppingCart } from 'lucide-astro'; 

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { id, nombre, precio, imagen, categoria } = product;

// Usamos la primera imagen si es un array para el catálogo
const imagenPrincipal = Array.isArray(imagen) ? imagen[0] : imagen;

// Serializamos el objeto para el botón de compra
const productData = JSON.stringify(product);

const formatCurrency = (value: number) => {
  return new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(value);
};
---

<div class="group relative bg-white backdrop-blur-sm border border-brand-purple/5 p-4 md:p-6 rounded-[2.5rem] transition-all duration-700 ease-out flex flex-col h-full hover:shadow-[0_20px_50px_rgba(59,27,84,0.06)] hover:-translate-y-1.5 hover:bg-white/90">
  
  {/* Enlace ajustado a la nueva ruta /catalogo/[id] */}
  <a href={`/catalogo/${id}`} class="absolute inset-0 z-10" aria-label={`Ver detalles de ${nombre}`}></a>

  <div class="relative aspect-square mb-4 md:mb-6 overflow-hidden bg-[#fdf2f2] rounded-3xl shrink-0">
    <img 
      src={imagenPrincipal} 
      alt={nombre} 
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-1000 ease-in-out group-hover:scale-110"
      style={`view-transition-name: product-img-${id};`} 
    />
    
    <div class="absolute top-3 left-3 bg-white/80 backdrop-blur-md px-3 py-1 rounded-full z-20 shadow-sm border border-brand-purple/5">
      <p class="text-[8px] md:text-[9px] font-bold text-brand-purple tracking-[0.2em] uppercase">
        {categoria}
      </p>
    </div>
  </div>

  <div class="flex flex-col flex-1 relative z-20 px-1">
    <h3 class="text-sm md:text-base font-bold text-brand-purple tracking-wide uppercase leading-snug group-hover:text-brand-gold transition-colors duration-500 line-clamp-2 min-h-10">
      {nombre}
    </h3>
    
    <div class="w-8 h-[1.5px] bg-brand-gold/30 my-3 group-hover:w-16 group-hover:bg-brand-gold/60 transition-all duration-700"></div>

    <div class="flex items-center justify-between mt-auto gap-2">
      <div class="flex flex-col">
        <span class="text-lg md:text-xl font-bold text-brand-purple tracking-tight">
          {formatCurrency(precio)}
        </span>
      </div>
      
      <button 
        type="button"
        class="add-to-cart-btn relative z-30 bg-brand-purple text-white p-3.5 hover:bg-brand-gold transition-all duration-500 active:scale-90 shadow-lg shadow-brand-purple/10 flex items-center justify-center rounded-2xl group/btn"
        data-product={productData}
        aria-label="Añadir al carrito"
      >
        <ShoppingCart 
          size={22}
          strokeWidth={1.5}
          class="text-white group-hover:scale-110 transition-transform duration-300"
        />
      </button>
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  import { addToCart } from "../../store/cartStore";

  function initCartButtons() {
    const buttons = document.querySelectorAll('.add-to-cart-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault(); // Evitamos que el clic active el enlace de la card
        const productData = JSON.parse(btn.getAttribute('data-product') || '{}');
        addToCart(productData);
        
        // Efecto visual rápido
        btn.classList.add('scale-110', '!bg-brand-gold');
        setTimeout(() => btn.classList.remove('scale-110', '!bg-brand-gold'), 500);
      });
    });
  }

  document.addEventListener("astro:page-load", initCartButtons);
</script>