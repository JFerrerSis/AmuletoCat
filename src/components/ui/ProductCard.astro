---
// src/components/ui/ProductCard.astro
import type { Product } from '../../types/product'; 

interface Props extends Product {}
const { id, nombre, precio, imagen, categoria } = Astro.props;
---

<div class="group relative bg-[#0d0e12]/90 border border-white/5 p-3 md:p-4 rounded-md hover:border-neon-green/40 transition-all duration-500 shadow-2xl overflow-hidden flex flex-col h-full hover:shadow-[0_8px_32px_rgba(0,0,0,0.6)]">
  
  <a href={`/catalogo/producto/${id}`} class="absolute inset-0 z-10" aria-label={`Ver detalles de ${nombre}`}></a>

  <div class="absolute inset-0 bg-linear-to-b from-transparent via-neon-green/5 to-transparent -translate-y-full group-hover:animate-[scan_2s_linear_infinite] pointer-events-none z-0"></div>

  <div class="relative aspect-square mb-4 overflow-hidden bg-black/40 border border-white/5 rounded shrink-0">
    <img 
      src={imagen} 
      alt={nombre} 
      class="w-full h-full object-cover transition-all duration-700 opacity-100 group-hover:scale-110"
      style={`view-transition-name: card-${id};`} 
    />
    <div class="absolute top-0 left-0 bg-black/95 border-b border-r border-neon-green/20 px-2.5 py-1 z-20 rounded-tl rounded-br">
      <p class="text-[7px] font-mono text-neon-green tracking-[0.2em] uppercase italic">{categoria}</p>
    </div>
  </div>

  <div class="space-y-2 relative z-20 flex-1 flex flex-col justify-between">
    <div class="min-h-10">
        <h3 class="text-base md:text-lg font-black text-white italic uppercase tracking-tighter leading-none group-hover:text-neon-green transition-colors">
          {nombre}
        </h3>
    </div>
    
    <div class="flex items-center justify-between pt-2 border-t border-white/5 mt-auto">
      <div class="flex flex-col">
        <span class="text-lg md:text-xl font-mono font-bold text-white/90 tracking-tighter">
          ${precio.toFixed(2)}
        </span>
      </div>
      
      <button 
        type="button"
        class="add-to-cart-btn relative z-30 bg-neon-green text-black px-4 py-3 md:py-2 text-[10px] font-black uppercase italic hover:bg-white transition-all active:scale-95 shadow-[0_0_20px_rgba(0,245,212,0.15)] flex items-center gap-2 rounded-sm"
        data-product={JSON.stringify({ id, nombre, precio, imagen, categoria })}
      >
        <span>Adquirir</span>
      </button>
    </div>
  </div>
</div>

<style>
  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
</style>